# Copy this to .env and fill in values before running the app.
# Example:
#   cp .env.example .env

# Anthropic / Claude API key for assistant (Claude Code compatible)
ANTHROPIC_API_KEY=
CLAUDE_CODE_API_KEY=
CLAUDE_API_KEY=

# Unusual Whales API token for UW-backed PI commands (scanner/discover/fetch_*).
UW_TOKEN=

# Optional: explicit model override
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Optional: explicit API endpoint override
# ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages

# Optional: websocket URL for the Node realtime price server.
IB_REALTIME_WS_URL=ws://localhost:8765
